<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body{
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        h1{
            text-align: center;
        }
        .formname{
            display: flex;
            flex-direction: column;
            width: 300px;
            margin: auto;
        }
        #btn{
            margin-top: 20px;
            background-color: #007BFF;
            color: black;
            padding: 0.5rem;
            border-color: #007BFF;
        }
        
        
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup</title>
</head>

<body>
    <h1>Signup</h1>
    <form class="formname" action="/user" method="post">
        <label >Full Name</label>
        <input type="text" required name="name" placeholder="Enter Your Full Name"/>
        <label >Email</label>
        <input type="text" required name="email" placeholder="Enter Your Email"/>
        <label >Password</label>
        <input type="text" required name="password" placeholder="Enter Your Password"/>
        <br>
        <button type="submit" id="btn">
            Signup
        </button>
    </form>
</body>
</html>