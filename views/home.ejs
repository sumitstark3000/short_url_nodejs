<!DOCTYPE html>
<html lang="en">

<head>
    <style>
        body{
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .for{
            display: flex;
            flex-direction: column;
            width: 300px;
            margin: auto;
        }
        .title{
            text-align: center;
        }
        #btn{
            margin-top: 20px;
            background-color: #007BFF;
            color: black;
            padding: 0.5rem;
            border-color: #007BFF;
        }
        .tb{
            margin: auto;
            margin-top: 20px;
            border-collapse: collapse;
        }
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1 class="title">URL Shortener</h1>
    <% if (locals.id) { %>
     <p>URL Generated: https://localhost:8001/url/<%= id %></p>
    <% } %>
    <div>
        <form method="POST" action="/url" class="for">
            <label>Enter Your Original Url</label>
            <input type="text" name="url" placeholder="https://example.com"/>
            <button type="submit" id="btn">Generate</button>
        </form>
    </div>
    <div>
        <% if (locals.urls) { %>
            <table class="tb">
                <thead>
                    <th>S.No</th>
                    <th>ShortID</th>
                    <th>Redirect</th>
                    <th>Clicks</th>
                </thead>
                <tbody>
                    <% urls.forEach((url,index) => { %>
                        <tr>
                        <td><%= index + 1 %></td>
                        <td><%= url.shortId %></td>
                        <td><%= url.redirectUrl %></td>
                        <td><%= url.visitHistory.length %></td>
                    </tr>
                     
                    <% }) %>
                </tbody>
            </table>
         
        <% } %>
    </div>
</body>

</html> 